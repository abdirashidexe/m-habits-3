  "motivation": {
    "0": {
      "text": "اللہ کو سب سے محبوب اعمال وہ ہیں جو دائمی ہوں، خواہ تھوڑے ہوں۔",
      "source": "حدیث — بخاری ومسلم"
    },
    "1": {
      "text": "اللہ کسی پر اس سے زیادہ بوجھ نہیں ڈالتا جتنا وہ سہ سکے — ایک ایک قدم۔",
      "source": "قرآن — ۲:۲۸۶"
    },
    "2": {
      "text": "بے شک مشکل کے ساتھ آسانی ہے۔",
      "source": "قرآن — ۹۴:۵–۶"
    },
    "3": {
      "text": "اپنی اونٹ باندھو، پھر اللہ پر بھروسہ کرو۔",
      "source": "حدیث — ترمذی"
    },
    "4": {
      "text": "مضبوط مومن بہتر اور اللہ کو زیادہ محبوب ہے کمزور مومن سے۔",
      "source": "حدیث — مسلم"
    },
    "5": {
      "text": "اللہ سے ڈرو، تمہیں وہ تم سے پہلے ملے گا۔",
      "source": "حدیث — ترمذی"
    },
    "6": {
      "text": "دنیا مومن کی جیل اور کافر کی جنت ہے۔",
      "source": "حدیث — مسلم"
    },
    "7": {
      "text": "جو علم کی راہ چلے اللہ اسے جنت کا راستہ آسان کر دے۔",
      "source": "حدیث — مسلم"
    },
    "8": {
      "text": "دل کو فانی سے نہ باندھو — پائیدار گھر بناؤ۔",
      "source": "یاد دہانی"
    },
    "9": {
      "text": "اللہ صبر والوں کے ساتھ ہے — اخلاص سے جاری رکھو۔",
      "source": "قرآن — ۲:۱۵۳"
    }
  },
