    },
    "3": {
      "text": "اعقلها وتوكل.",
      "source": "حديث — الترمذي"
    },
    "4": {
      "text": "المؤمن القوي خير وأحب إلى الله من المؤمن الضعيف.",
      "source": "حديث — مسلم"
    },
    "5": {
      "text": "اتق الله تجده أمامك.",
      "source": "حديث — الترمذي"
    },
    "6": {
      "text": "الدنيا سجن المؤمن وجنة الكافر.",
      "source": "حديث — مسلم"
    },
    "7": {
      "text": "من سلك طريقاً يلتمس فيه علماً سهل الله له طريقاً إلى الجنة.",
      "source": "حديث — مسلم"
    },
    "8": {
      "text": "لا تلزم قلبك ما يفنِ — ابنِ للدار الباقية.",
      "source": "تذكير"
    },
    "9": {
      "text": "إن الله مع الصابرين — واصل بإخلاص.",
      "source": "قرآن — البقرة ١٥٣"
