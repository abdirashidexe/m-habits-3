# Copy to `.env` for local dev. For EAS production builds, set secrets in EAS / CI — do not commit `.env`.

# RevenueCat — public test key (inlined in JS; safe for dev builds)
EXPO_PUBLIC_RC_TEST_KEY=

# RevenueCat — production (use EXPO_PUBLIC_* so Metro bundles them for release; optional legacy names below)
EXPO_PUBLIC_REVENUE_CAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUE_CAT_ANDROID_API_KEY=
REVENUE_CAT_IOS_API_KEY=
REVENUE_CAT_ANDROID_API_KEY=
